# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase CLI (for db:setup – generate at https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=your_supabase_access_token
SUPABASE_REF=your_project_reference_id

# Admin Panel
ADMIN_PASSWORD=your_admin_password
JWT_SECRET=your_jwt_secret

# Client origin (for CORS — set to your Vercel URL in production)
CLIENT_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Payment account details (returned by GET /api/config)
BANK_NAME=Meezan Bank
BANK_ACCOUNT_TITLE=Global Tickets Pvt Ltd
BANK_ACCOUNT_NUMBER=0123-0123456789
BANK_IBAN=PK00MEZN0001234567890
EASYPAISA_NUMBER=0300-0000000
EASYPAISA_TITLE=Global Tickets
CONTACT_WHATSAPP=+923000000000

# SMTP (for ticket email — use Mailtrap for testing)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=noreply@globaltickets.com

# Server
PORT=3000
